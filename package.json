{
  "name": "wardsuite.hcm",
  "private": true,
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently -n \"API,WEB\" -c \"cyan,magenta\" \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "tsx --env-file=.env apps/api/main.ts",
    "dev:web": "cd apps/web && vite",
    "build": "vite build --config apps/web/vite.config.ts && esbuild apps/api/main.ts --bundle --platform=node --format=esm --packages=external --outfile=dist/server.js",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"apps/**/src/**/*.{ts,tsx,js,jsx}\" \"libs/**/src/**/*.{ts,tsx,js,jsx}\" --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint \"apps/**/src/**/*.{ts,tsx,js,jsx}\" \"libs/**/src/**/*.{ts,tsx,js,jsx}\" --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css,scss,html}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css,scss,html}\"",
    "preview": "vite preview",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "hcm",
    "human capital management"
  ],
  "author": "Eduardo M.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "prettier": "^3.8.3",
    "typescript": "^5.5.0"
  }
}