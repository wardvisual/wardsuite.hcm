{
  "name": "wardsuite.hcm",
  "private": true,
  "version": "1.0.0",
  "description": "Mini HCM Time Tracking System",
  "scripts": {
    "dev": "concurrently -n \"API,WEB\" -c \"cyan,magenta\" \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "npm run dev --workspace=api",
    "dev:web": "npm run dev --workspace=web",
    "emulate": "npx firebase emulators:start",

    "build": "npm run build --workspace=api && npm run build --workspace=web",
    "build:api": "npm run build --workspace=api",
    "build:web": "npm run build --workspace=web",

    "check": "npm run typecheck && npm run lint && npm run format:check",
    "typecheck": "npm run typecheck:api && npm run typecheck:web",
    "typecheck:api": "npm run typecheck --workspace=api",
    "typecheck:web": "npm run typecheck --workspace=web",
    "lint": "eslint \"apps/**/src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"apps/**/src/**/*.{ts,tsx}\" --fix",
    "format": "prettier --write \"apps/**/*.{ts,tsx,json,css}\"",
    "format:check": "prettier --check \"apps/**/*.{ts,tsx,json,css}\"",

    "migrate": "npm run migrate --workspace=api",
    "migrate:status": "npm run migrate:status --workspace=api",
    "seed": "npm run seed --workspace=api",

    "firebase:deploy:rules": "npx firebase deploy --only firestore:rules",
    "firebase:deploy:indexes": "npx firebase deploy --only firestore:indexes",
    "firebase:deploy:hosting": "npx firebase deploy --only hosting",

    "deploy": "docker-compose up -d --build --force-recreate --remove-orphans",
    "deploy:web": "cross-env VITE_API_BASE_URL=https://hcmapi.wardvisual.com/api npm run build:web && npm run firebase:deploy:hosting",
    "deploy:logs": "docker-compose logs -f",
    "deploy:stop": "docker-compose down --remove-orphans",

    "docker:build": "docker build -t wardsuite-hcm .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f api",
    "docker:restart": "docker-compose restart api",

    "clean": "rimraf apps/api/dist apps/web/dist"
  },
  "keywords": [
    "hcm",
    "time-tracking"
  ],
  "author": "Eduardo M.",
  "workspaces": [
    "apps/*"
  ],
  "devDependencies": {
    "@types/firebase": "^2.4.32",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "firebase-tools": "^15.17.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0"
  }
}
