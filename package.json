{
  "name": "wardsuite.hcm",
  "private": true,
  "version": "1.0.0",
  "description": "Mini HCM Time Tracking System",
  "scripts": {
    "dev": "concurrently -n \"API,WEB\" -c \"cyan,magenta\" \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "npm run dev --workspace=api",
    "dev:web": "npm run dev --workspace=web",
    "build": "npm run build --workspace=api && npm run build --workspace=web",
    "build:api": "npm run build --workspace=api",
    "build:web": "npm run build --workspace=web",
    "typecheck": "npm run typecheck --workspace=api && tsc -p apps/web --noEmit",
    "migrate": "npm run migrate --workspace=api",
    "migrate:status": "npm run migrate:status --workspace=api",
    "lint": "eslint \"apps/**/src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"apps/**/src/**/*.{ts,tsx}\" --fix",
    "format": "prettier --write \"apps/**/*.{ts,tsx,json,css}\"",
    "format:check": "prettier --check \"apps/**/*.{ts,tsx,json,css}\"",
    "clean": "rimraf apps/api/dist apps/web/dist"
  },
  "keywords": [
    "hcm",
    "time-tracking"
  ],
  "author": "Eduardo M.",
  "workspaces": [
    "apps/*"
  ],
  "devDependencies": {
    "@types/firebase": "^2.4.32",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0"
  }
}
